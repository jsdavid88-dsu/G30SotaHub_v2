# =============================================================================
# G30SotaHub v2 — 환경 변수 예제
# 실제 .env 파일에 복사 후 값을 채워 넣으세요. (.env 는 git ignored)
# =============================================================================

# === Database (Postgres) ===
# setup.ps1 이 docker compose 로 db 컨테이너 띄우면 아래 기본값 그대로 사용.
# - mac / linux:  asyncpg 권장 (안정)
# - Windows:      psycopg(v3) 권장 (asyncpg 는 일부 환경에서 디버깅 어려움 — Issue #5)
DB_PASSWORD=hub
DATABASE_URL=postgresql+asyncpg://hub:hub@localhost:5432/hub
# Windows 에서 디버깅 어려우면 아래 한 줄로 교체:
# DATABASE_URL=postgresql+psycopg://hub:hub@localhost:5432/hub

# === App ===
APP_NAME=G30SotaHub_v2
DEBUG=true
SECRET_KEY=change-me-to-random-32-char-string
FRONTEND_URL=http://localhost:3000

# === Google OAuth (선택) ===
# DEBUG=true 면 dev-login 으로 OAuth 없이도 접속 가능 — 이 키들은 나중에 채워도 OK
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
GOOGLE_CALENDAR_ENABLED=true

# === Web Push (VAPID, 선택) ===
# 푸시 알림 안 쓰면 비워둬도 됨
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# === 암호화 키 (선택) ===
# 비워두면 SECRET_KEY 에서 자동 파생
ENCRYPTION_KEY=

# =============================================================================
# === VFX SOTA Monitor 통합 설정 (vfx-sota-monitor 흡수) ===
# =============================================================================

# 외부 API 토큰 (선택, 비워두면 해당 소스 스킵)
GITHUB_TOKEN=
HF_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=g30sotahub-v2

# AI Cluster Worker 인증 (Hub admin token 과 같이 사용)
ADMIN_TOKEN=change-me-to-random-string

# Crawl4AI / Firecrawl
FIRECRAWL_BASE_URL=http://localhost:3002
FIRECRAWL_ENABLED=false

# Ollama (로컬 LLM — 단일 5090 PC 운용 시 localhost)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b

# NAS / Storage (Phase 3 영상 첨부 — 비워두면 backend/uploads/ fallback)
# 예: NAS_BASE_PATH=M:\sota_files
NAS_BASE_PATH=

# APScheduler 토글 (false 로 두면 정기 크롤 / 야간 배치 / 주간 리포트 비활성화)
SCHEDULER_ENABLED=true
