# =============================================================================
# G30SotaHub v2 — 환경 변수 예제
# 실제 .env 파일에 복사 후 값을 채워 넣으세요. (.env 는 git ignored)
#
# 토큰 / 외부 서비스 사전 조건은 README.md 의 "📋 작업별 사전 조건 (수집/분석)" 표 참고.
# =============================================================================

# === Database (Postgres) ===
# setup.ps1 이 docker compose 로 db 컨테이너 띄우면 아래 기본값 그대로 사용.
# - mac / linux:  asyncpg 권장 (안정)
# - Windows:      psycopg(v3) 권장 (asyncpg 는 일부 환경에서 디버깅 어려움)
DB_PASSWORD=hub
DATABASE_URL=postgresql+asyncpg://hub:hub@localhost:5432/hub
# Windows 에서 디버깅 어려우면 아래 한 줄로 교체:
# DATABASE_URL=postgresql+psycopg://hub:hub@localhost:5432/hub

# === App ===
APP_NAME=G30SotaHub_v2
DEBUG=true
SECRET_KEY=change-me-to-random-32-char-string
FRONTEND_URL=http://localhost:3030

# === Google OAuth (선택) ===
# DEBUG=true 면 dev-login 으로 OAuth 없이도 접속 가능
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8011/api/v1/auth/callback
GOOGLE_CALENDAR_ENABLED=true

# === Web Push (VAPID, 선택) — 푸시 알림 안 쓰면 비워둠 ===
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# === 암호화 키 (선택) — 비워두면 SECRET_KEY 에서 파생 ===
ENCRYPTION_KEY=

# =============================================================================
# 🎬 VFX SOTA Monitor 통합 설정
# =============================================================================

# ─── 외부 크롤 소스 토큰 ────────────────────────────────────────────────────
# 비워두면 해당 소스는 [빠른 수집] 시 skip 됨. arxiv 만 항상 동작.

# GitHub: anonymous 면 60req/h. 토큰 발급 → https://github.com/settings/tokens
#   필요 권한: public_repo (읽기만)
GITHUB_TOKEN=

# HuggingFace: anonymous 도 public 모델/논문 OK. 토큰은 rate limit 완화용.
#   발급 → https://huggingface.co/settings/tokens
HF_TOKEN=

# Reddit: 없으면 Reddit 크롤 완전 skip. 발급:
#   https://www.reddit.com/prefs/apps → "create another app" → "script" 선택
#   생성된 client_id (App 이름 아래 14자리) 와 secret 복사
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=g30sotahub-v2

# X (Twitter): Playwright 로그인 세션 필요 (data/x_browser_profile/).
# 첫 사용 시 한 번 로그인하면 세션 저장됨. 별도 토큰 환경변수 X.

# Crawl4AI / Firecrawl (웹 크롤) — 필요시 별도 서비스 띄움
#   docker run -p 3002:3002 mendableai/firecrawl
FIRECRAWL_BASE_URL=http://localhost:3002
FIRECRAWL_ENABLED=false

# ─── Gemma 4 (Ollama) ─────────────────────────────────────────────────────
# [야간 배치] 의 진짜 분석을 담당. 미설치면 야간 배치가 Gemma 호출 부분만 skip.
#   설치: https://ollama.com/download
#   모델 받기: ollama pull gemma4:26b
#   서버 떠있는지: curl http://localhost:11434/api/tags
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b

# ─── AI Cluster Worker 인증 (별도 GPU PC 분리 운용 시) ──────────────────────
# 같은 PC 에서 Ollama 돌리면 무관. 워커가 백엔드 호출 시 X-Admin-Token 헤더로 사용.
ADMIN_TOKEN=change-me-to-random-string

# ─── NAS / Storage (Phase 3 영상 첨부) ────────────────────────────────────
# 비워두면 backend/uploads/ 사용. NAS 마운트 시 절대 경로:
# 예: NAS_BASE_PATH=M:\sota_files
NAS_BASE_PATH=

# ─── APScheduler ──────────────────────────────────────────────────────────
# 정기 크롤(09:00) + 야간 배치(21:00 KST). false 로 두면 다 비활성화.
SCHEDULER_ENABLED=true
